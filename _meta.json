{
  "schema": "openclaw.skill.v1",
  "name": "blog-generator",
  "version": "1.1.0",
  "displayName": "Blog Generator",
  "description": "Analyzes journal entries and chat history to identify high-value topics and automatically generate structured blog posts with problem/solution format. Supports cron scheduling, configurable scoring weights, and JSON output.",
  "author": "RuneweaverStudios",
  "tags": [
    "blog",
    "content-creation",
    "generation",
    "cron",
    "python",
    "journal",
    "seo",
    "automation",
    "markdown",
    "topic-scoring",
    "problem-solution"
  ],
  "platform": "openclaw",
  "main": "scripts/blog_generator.py",
  "requires": {
    "optionalEnv": [
      "OPENCLAW_HOME"
    ],
    "anyBins": [
      "python3"
    ]
  },
  "fileAccess": {
    "read": [
      "$OPENCLAW_HOME/journal/ (journal markdown files)"
    ],
    "write": [
      "$OPENCLAW_HOME/blogs/ (generated blog posts)"
    ]
  },
  "dependencies": []
}